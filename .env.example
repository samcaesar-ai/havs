# ── Email notifications (Resend) ─────────────────────────────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# ── Google Sheets integration ─────────────────────────────────────────────────
# 1. Create a Google Cloud project and enable the Sheets API
# 2. Create a Service Account, download the JSON key file
# 3. Base64-encode the JSON: base64 -i service-account.json | tr -d '\n'
# 4. Paste the result below
GOOGLE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50...

# The Sheets spreadsheet ID (from the URL: /spreadsheets/d/<ID>/edit)
HAVS_SHEET_ID=1abc2def3ghi4jkl5mno6pqr7stu8vwx

# ── Cal.com booking embed (optional) ─────────────────────────────────────────
# The Cal.com username/event-slug, e.g. "davidhav/intro"
# Leave blank to hide the booking widget
NEXT_PUBLIC_CAL_LINK=davidhav/intro
